# Ad Intelligence Dashboard - Security Rules

# Deny access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to config directory
    RewriteRule ^config/ - [F,L]

    # Block access to src directory
    RewriteRule ^src/ - [F,L]

    # Block access to cron directory
    RewriteRule ^cron/ - [F,L]

    # Block access to logs directory
    RewriteRule ^logs/ - [F,L]

    # Block access to database directory
    RewriteRule ^database/ - [F,L]
</IfModule>

# Block direct access to .php files in src/
<FilesMatch "^(config|src|cron|logs|database)/">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent directory listing
Options -Indexes
